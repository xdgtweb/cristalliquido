const root = document.documentElement;

// Nodos SVG
const feDisplacement = document.getElementById('svg-refraccion');
const caRed = document.getElementById('svg-ca-red');
const caBlue = document.getElementById('svg-ca-blue');

// Toggles
const tgl3D = document.getElementById('toggle-3d');
const tglSpecular = document.getElementById('toggle-specular');
const tglBlur = document.getElementById('toggle-blur');
const tglSpring = document.getElementById('toggle-spring');
const tglLift = document.getElementById('toggle-lift'); // Nuevo toggle

// Sliders
const sRefraccion = document.getElementById('ctrl-refraccion');
const sChroma = document.getElementById('ctrl-chroma');
const sGrosor = document.getElementById('ctrl-grosor');
const sRadius = document.getElementById('ctrl-radius');
const sBrillo = document.getElementById('ctrl-brillo');
const sBlur = document.getElementById('ctrl-blur');

const glassWrapper = document.getElementById('mini-glass-wrapper');
const interactiveNav = document.getElementById('interactive-nav');
const interactiveContent = document.getElementById('interactive-content');
const vRefraccion = document.getElementById('val-refraccion');
const vChroma = document.getElementById('val-chroma');
const vGrosor = document.getElementById('val-grosor');
const vRadius = document.getElementById('val-radius');
const vBrillo = document.getElementById('val-brillo');
const vBlur = document.getElementById('val-blur');

let previewActiveFrames = 0;

function updateEffects() {
    // Cuando tocamos un slider o toggle, activamos el "preview" para ver el efecto líquido
    previewActiveFrames = 120; // 2 segundos a 60fps
    
    let grosor = sGrosor.value;
    root.style.setProperty('--glass-grosor', grosor + 'px');
    vGrosor.textContent = grosor;

    let radius = sRadius.value;
    root.style.setProperty('--glass-radius', radius + 'px');
    vRadius.textContent = radius + 'px';
    
    // Y actualizamos textos de UI
    vRefraccion.textContent = sRefraccion.value;
    vChroma.textContent = sChroma.value;
    vBrillo.textContent = sBrillo.value;
    vBlur.textContent = parseFloat(sBlur.value).toFixed(2) + 'px';
}

[sRefraccion, sChroma, sGrosor, sRadius, sBrillo, sBlur].forEach(slider => {
    slider.addEventListener('input', updateEffects);
});
[tgl3D, tglSpecular, tglBlur, tglSpring, tglLift].forEach(tgl => {
    tgl.addEventListener('change', updateEffects);
});

// --- LÓGICA DE DRAG & DROP Y FÍSICAS (Squash & Stretch) ---
const navWrapper = document.getElementById('nav-wrapper');

let isDragging = false;
let wasDragged = false;
let dragStartX = 0;
let startX = 0;
let currentX = 0; // px
let targetIdx = 0; // 0 o 1
const tabWidth = 120; // 240 / 2
const maxTravel = 120; // 240 - 120

let lastX = 0;
let smoothedDx = 0;
let currentLift = 0; // Para el efecto Z-Axis despegado

function setPosition(x, animate = false) {
    if (animate) {
        let isSpring = tglSpring.checked;
        root.style.setProperty('--spring-dur', isSpring ? '0.6s' : '0.3s');
        root.style.setProperty('--spring-ease', isSpring ? 'cubic-bezier(0.34, 1.56, 0.64, 1)' : 'ease-out');
        
        glassWrapper.classList.add('animated');
        if (interactiveContent) interactiveContent.classList.add('animated');
    } else {
        glassWrapper.classList.remove('animated');
        if (interactiveContent) interactiveContent.classList.remove('animated');
    }
    
    currentX = Math.max(0, Math.min(x, maxTravel));
    root.style.setProperty('--glass-x', currentX);
}

function physicsLoop() {
    let actualX = 0;
    if (glassWrapper) {
        // En movimiento CSS o Drag, leemos la posición X real actual
        const style = window.getComputedStyle(glassWrapper);
        const matrix = new WebKitCSSMatrix(style.transform);
        actualX = matrix.m41;
    }
    
    const rawDx = actualX - lastX;
    lastX = actualX;
    
    // Filtro LERP para evitar temblores
    smoothedDx = smoothedDx * 0.85 + rawDx * 0.15;
    const absDx = Math.abs(smoothedDx);
    
    // --- EFECTO CRISTAL LÍQUIDO INTELIGENTE ---
    if (previewActiveFrames > 0) previewActiveFrames--;
    
    let targetLift = 0;
    let effectMultiplier = 1; // 1 = Cristal Mágico, 0 = Pastilla Plana
    
    if (tglLift && tglLift.checked) {
        if (isDragging || absDx > 0.5 || previewActiveFrames > 0) {
            targetLift = 1; // Se vuelve líquido y se despega
        }
        // Suavizado del cambio de estado
        currentLift = currentLift * 0.85 + targetLift * 0.15;
        effectMultiplier = currentLift;
    } else {
        // Si el toggle está apagado, siempre está levantado/líquido (comportamiento anterior)
        currentLift = currentLift * 0.85 + 1 * 0.15;
        effectMultiplier = 1;
    }
    
    root.style.setProperty('--glass-lift', currentLift.toFixed(3));
    
    // Variables ópticas globales
    let feDispBg = document.getElementById('svg-refraccion-bg');
    let caRed = document.getElementById('svg-ca-red');
    let caBlue = document.getElementById('svg-ca-blue');
    
    // Aplicamos los valores de los sliders
    let refraccion = tgl3D.checked ? parseFloat(sRefraccion.value) : 0;
    let grosor = parseFloat(sGrosor.value);
    
    let effectScale = -((refraccion * 0.7) + (grosor * 1.5));
    if (feDispBg) feDispBg.setAttribute('scale', effectScale);

    let chroma = parseFloat(sChroma.value);
    if (caRed) caRed.setAttribute('dx', chroma * effectMultiplier);
    if (caBlue) caBlue.setAttribute('dx', -chroma * effectMultiplier);

    let brilloRaw = sBrillo.value;
    let brilloAlpha = tglSpecular.checked ? (brilloRaw / 100) : 0;
    let specularBorder = tglSpecular.checked ? (brilloRaw / 200) : 0;
    root.style.setProperty('--glass-brillo-alpha', (brilloAlpha * effectMultiplier).toFixed(3));
    root.style.setProperty('--glass-specular-border', `rgba(255, 255, 255, ${(specularBorder * effectMultiplier).toFixed(3)})`);

    let blurVal = sBlur.value;
    // Si el blur está desactivado, es 0. Si está activado, aplicamos el blur base + un aumento focal si está despegado
    let finalBlur = tglBlur.checked ? (parseFloat(blurVal) * effectMultiplier) + (currentLift * 3) : 0;
    root.style.setProperty('--glass-blur', finalBlur + 'px');
    
    const radiusVal = parseInt(sRadius.value) || 15;
    
    if (absDx < 0.1 && !isDragging) {
        // IDLE (Pastilla estable, sin movimiento en bucle)
        root.style.setProperty('--squash-x', 1);
        root.style.setProperty('--squash-y', 1);
        
        root.style.setProperty('--br-tl', radiusVal + 'px');
        root.style.setProperty('--br-tr', radiusVal + 'px');
        root.style.setProperty('--br-bl', radiusVal + 'px');
        root.style.setProperty('--br-br', radiusVal + 'px');
    } else {
        // MOVIMIENTO (Física de inercia y rebote de gota)
        const stretch = 1 + (absDx * 0.03);
        const squash = Math.max(0.6, 1 - (absDx * 0.015));
        
        root.style.setProperty('--squash-x', stretch);
        root.style.setProperty('--squash-y', squash);
        
        // Teardrop: El lado de avance es redondo, la cola se afila
        let leadRadius = radiusVal; 
        let trailRadius = Math.max(6, radiusVal - absDx * 1.5); 
        
        if (smoothedDx > 0) {
            // Moviendo a la derecha
            root.style.setProperty('--br-tl', trailRadius + 'px');
            root.style.setProperty('--br-tr', leadRadius + 'px');
            root.style.setProperty('--br-br', leadRadius + 'px');
            root.style.setProperty('--br-bl', trailRadius + 'px');
        } else if (smoothedDx < 0) {
            // Moviendo a la izquierda
            root.style.setProperty('--br-tl', leadRadius + 'px');
            root.style.setProperty('--br-tr', trailRadius + 'px');
            root.style.setProperty('--br-br', trailRadius + 'px');
            root.style.setProperty('--br-bl', leadRadius + 'px');
        }
    }
    
    requestAnimationFrame(physicsLoop);
}

// Drag & Drop
const clickLayer = document.getElementById('click-layer');
if (clickLayer) {
    clickLayer.addEventListener('pointerdown', (e) => {
        isDragging = true;
        wasDragged = false;
        dragStartX = e.clientX;
        startX = e.clientX - currentX;
        clickLayer.setPointerCapture(e.pointerId);
    });

    clickLayer.addEventListener('pointermove', (e) => {
        if (!isDragging) return;
        if (Math.abs(e.clientX - dragStartX) > 3) {
            wasDragged = true;
        }
        const x = e.clientX - startX;
        setPosition(x, false); // false = arrastre manual sin transición
    });

    clickLayer.addEventListener('pointerup', (e) => {
        if (!isDragging) return;
        isDragging = false;
        clickLayer.releasePointerCapture(e.pointerId);
        
        // Efecto imán: decide a qué lado ir según donde soltaste
        if (currentX > maxTravel / 2) {
            targetIdx = 1;
            setPosition(maxTravel, true); // true = transición suave
        } else {
            targetIdx = 0;
            setPosition(0, true);
        }
    });

    clickLayer.addEventListener('pointercancel', () => {
        if (!isDragging) return;
        isDragging = false;
        wasDragged = false;
        setPosition(targetIdx * maxTravel, true);
    });

    // Clic en los textos para cambiar
    clickLayer.addEventListener('click', (e) => {
        if (wasDragged) {
            wasDragged = false;
            return; // Ignoramos el clic porque el usuario estaba arrastrando
        }
        const rect = clickLayer.getBoundingClientRect();
        const clickX = e.clientX - rect.left;
        if (clickX > tabWidth) {
            targetIdx = 1;
            setPosition(maxTravel, true);
        } else {
            targetIdx = 0;
            setPosition(0, true);
        }
    });
}

// Inicializar
updateEffects();

// --- GENERADOR DE NORMAL MAP 3D PARA LENTE PERFECTA ---
function updateLensMap() {
    const wrapper = document.getElementById('mini-glass-base');
    if (!wrapper) return;
    const width = wrapper.offsetWidth;
    const height = wrapper.offsetHeight;
    if (width === 0 || height === 0) return;
    
    const canvas = document.createElement('canvas');
    canvas.width = width;
    canvas.height = height;
    const ctx = canvas.getContext('2d');
    const imgData = ctx.createImageData(width, height);
    const data = imgData.data;
    
    const radius = height / 2;
    const ax = radius;
    const bx = width - radius;
    const cy = radius;
    // Power 3 = superellipse (centro plano, bordes curvos muy marcados)
    const power = 3;

    const getZ = (x, y) => {
        let cx = x;
        if (cx < ax) cx = ax;
        if (cx > bx) cx = bx;
        const vx = x - cx;
        const vy = y - cy;
        const d = Math.sqrt(vx*vx + vy*vy);
        if (d >= radius) return 0;
        const nd = d / radius;
        return Math.pow(1 - Math.pow(nd, power), 1/power) * radius;
    };

    for (let y = 0; y < height; y++) {
        for (let x = 0; x < width; x++) {
            const z0 = getZ(x, y);
            let nx = 0, ny = 0;
            if (z0 > 0) {
                const zx = getZ(x + 1, y);
                const zy = getZ(x, y + 1);
                let vx = z0 - zx;
                let vy = z0 - zy;
                let vz = 1;
                const len = Math.sqrt(vx*vx + vy*vy + vz*vz);
                nx = vx / len;
                ny = vy / len;
            }
            const index = (y * width + x) * 4;
            data[index] = Math.floor((nx + 1) * 127.5); // X -> R
            data[index+1] = Math.floor((ny + 1) * 127.5); // Y -> G
            data[index+2] = 255;
            data[index+3] = 255;
        }
    }
    ctx.putImageData(imgData, 0, 0);
    const feImg = document.getElementById('svg-lens-image');
    if (feImg) {
        feImg.setAttribute('href', canvas.toDataURL('image/png'));
    }
}

window.addEventListener('resize', updateLensMap);
setTimeout(updateLensMap, 50); // Generar al inicio

physicsLoop();
